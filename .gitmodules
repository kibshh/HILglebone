[submodule "stm32/vendor/cmsis_device_f4"]
	path = stm32/vendor/cmsis_device_f4
	url = https://github.com/STMicroelectronics/cmsis_device_f4.git
[submodule "stm32/vendor/cmsis_core"]
	path = stm32/vendor/cmsis_core
	url = https://github.com/STMicroelectronics/cmsis_core.git
[submodule "stm32/vendor/freertos_kernel"]
	path = stm32/vendor/freertos_kernel
	url = https://github.com/FreeRTOS/FreeRTOS-Kernel.git
