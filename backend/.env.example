# Copy to `.env` for local development. docker-compose picks it up
# automatically. All values below are dev-safe defaults; do NOT reuse
# any of these credentials outside localhost.

# Postgres
POSTGRES_USER=hilglebone
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=hilglebone

# MinIO — the root credentials also serve as the S3 access/secret pair
# the backend uses to sign firmware uploads/presigned URLs in dev.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=firmware

# Backend port on the host. The container always listens on :8080 inside
# the network; this is just the localhost mapping.
BACKEND_HOST_PORT=8080
