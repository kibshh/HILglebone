# Copy to `.env` for production deployments driven by
# docker-compose.prod.yml. Every value below is REQUIRED — the compose
# override uses ${VAR:?} so the stack refuses to start if any is missing.
#
# Do NOT commit the filled-in `.env`. Generate credentials with a
# password manager or `openssl rand -base64 32`; keep them in whatever
# secret store the deployment uses (Vault, sops, 1Password CLI, etc.).

# ── Postgres ─────────────────────────────────────────────────────
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# ── MinIO ────────────────────────────────────────────────────────
# The root user + password also serve as the S3 access/secret pair the
# backend uses to sign presigned firmware URLs.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_BUCKET=
# Public hostname the BBB reaches to download firmware. Must resolve
# from the BBB's network. TLS terminates here (reverse proxy or MinIO
# itself with real certs). Example: firmware.hilglebone.com
MINIO_PUBLIC_ENDPOINT=

# ── Backend ──────────────────────────────────────────────────────
# Host port the reverse proxy / ingress will forward to.
BACKEND_HOST_PORT=8080

# Comma-separated list of Origin patterns the WebSocket upgrader accepts.
# Example: WS_ALLOWED_ORIGINS=https://app.hilglebone.com,https://console.hilglebone.com
WS_ALLOWED_ORIGINS=
